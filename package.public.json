{
  "name": "@hiai-gg/docsmint",
  "version": "0.3.6",
  "type": "module",
  "browser": {
    "./dist/backend-launcher.js": false,
    "./dist/lifecycle.js": false,
	"./dist/lifecycle-persistent.js": false,
    "./dist/storage-quota.js": false,
    "./dist/workspace.js": false
  },
  "license": "Apache-2.0",
  "description": "The lightweight, AI-native self-hosted knowledge base — built-in RAG, hybrid semantic search, and a clean REST API for AI agents.",
  "repository": {
    "type": "git",
    "url": "https://github.com/HiAi-gg/docsmint"
  },
  "homepage": "https://github.com/hiai-gg/docsmint#readme",
  "bugs": {
    "url": "https://github.com/hiai-gg/docsmint/issues"
  },
  "keywords": [
    "knowledge-base",
    "ai-native",
    "wiki",
    "markdown",
    "ai-embeddings",
    "rag",
    "semantic-search",
    "self-hosted",
    "pgvector",
    "ollama",
    "local-llm",
    "pwa",
    "progressive-web-app",
    "offline-knowledge-base",
    "docsmint",
    "outline-alternative",
    "docmost-alternative"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lifecycle": {
      "browser": "./dist/server-only-browser-entry.js",
      "import": "./dist/lifecycle.js",
      "types": "./dist/lifecycle.d.ts"
    },
    "./lifecycle/persistent": {
      "browser": "./dist/server-only-browser-entry.js",
      "import": "./dist/lifecycle-persistent.js",
      "types": "./dist/lifecycle-persistent.d.ts"
    },
    "./workspace": {
      "browser": "./dist/server-only-browser-entry.js",
      "import": "./dist/workspace.js",
      "types": "./dist/workspace.d.ts"
    },
    "./backend/launcher": {
      "browser": "./dist/server-only-browser-entry.js",
      "import": "./dist/backend-launcher.js",
      "types": "./dist/backend-launcher.d.ts"
    },
    "./storage-quota": {
      "browser": "./dist/server-only-browser-entry.js",
      "import": "./dist/storage-quota.js",
      "types": "./dist/storage-quota.d.ts"
    },
    "./frontend/dashboard": {
      "import": "./dist/frontend/dashboard.js",
      "types": "./dist/frontend/dashboard.d.ts"
    },
    "./frontend/search": {
      "import": "./dist/frontend/search.js",
      "types": "./dist/frontend/search.d.ts"
    },
    "./frontend/shared-document": {
      "import": "./dist/frontend/shared-document.js",
      "types": "./dist/frontend/shared-document.d.ts"
    },
    "./frontend/extension": {
      "import": "./dist/frontend/extension.js",
      "types": "./dist/frontend/extension.d.ts"
    },
    "./frontend/api/categories": {
      "import": "./dist/frontend/api/categories.js",
      "types": "./dist/frontend/api/categories.d.ts"
    },
    "./frontend/api/documents": {
      "import": "./dist/frontend/api/documents.js",
      "types": "./dist/frontend/api/documents.d.ts"
    },
    "./frontend/api/folders": {
      "import": "./dist/frontend/api/folders.js",
      "types": "./dist/frontend/api/folders.d.ts"
    },
    "./frontend/api/tags": {
      "import": "./dist/frontend/api/tags.js",
      "types": "./dist/frontend/api/tags.d.ts"
    },
    "./frontend/api/settings": {
      "import": "./dist/frontend/api/settings.js",
      "types": "./dist/frontend/api/settings.d.ts"
    },
    "./frontend/components/sidebar": {
      "import": "./dist/frontend/components/sidebar.js",
      "types": "./dist/frontend/components/sidebar.d.ts"
    },
    "./frontend/components/settings": {
      "import": "./dist/frontend/components/settings.js",
      "types": "./dist/frontend/components/settings.d.ts"
    },
    "./frontend/theme": {
      "import": "./dist/frontend/theme.js",
      "types": "./dist/frontend/theme.d.ts"
    },
    "./frontend/i18n": {
      "import": "./dist/frontend/i18n.js",
      "types": "./dist/frontend/i18n.d.ts"
    },
    "./schema": {
      "import": "./packages/db/src/schema.ts",
      "types": "./packages/db/src/schema.ts"
    },
    "./db": {
      "import": "./packages/db/src/index.ts",
      "types": "./packages/db/src/index.ts"
    },
    "./db/client": {
      "import": "./packages/db/src/client.ts",
      "types": "./packages/db/src/client.ts"
    },
    "./db/with-tenant": {
      "import": "./packages/db/src/with-tenant.ts",
      "types": "./packages/db/src/with-tenant.ts"
    },
    "./backend/lib/redis": {
      "import": "./backend/src/lib/redis-factory.ts",
      "types": "./backend/src/lib/redis-factory.ts"
    },
    "./backend/lib/storage": {
      "import": "./backend/src/lib/storage-factory.ts",
      "types": "./backend/src/lib/storage-factory.ts"
    },
    "./backend/lib/logger": {
      "import": "./backend/src/lib/logger.ts",
      "types": "./backend/src/lib/logger.ts"
    }
  },
  "bin": {
    "docsmint": "./packages/cli/src/index.ts",
    "docsmint-mcp": "./packages/mcp-server/src/index.ts",
    "hiai-docs": "./packages/cli/src/index.ts",
    "hiai-docs-mcp": "./packages/mcp-server/src/index.ts"
  },
  "files": [
    "dist",
    "packages/db/src/index.ts",
    "packages/db/src/client.ts",
    "packages/db/src/schema.ts",
    "packages/db/src/with-tenant.ts",
    "packages/cli/src/index.ts",
    "packages/cli/src/client.ts",
    "packages/cli/src/config.ts",
    "packages/cli/src/format.ts",
    "packages/cli/src/commands",
    "packages/mcp-server/src/index.ts",
    "packages/mcp-server/src/client.ts",
    "packages/mcp-server/src/types.ts",
    "packages/mcp-server/src/tools",
    "backend/src/lib/redis-factory.ts",
    "backend/src/lib/storage-factory.ts",
    "backend/src/lib/logger.ts",
    "backend/src/lib/lifecycle-service.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">= 1.3.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "docker compose up -d",
    "build": "docker compose build",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "build:sdk": "cd packages/sdk && bun run build",
    "prepublishOnly": "cd packages/sdk && bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "ioredis": "^5.4.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "pino": "^10.0.0",
    "@sveltejs/kit": "^2.68.0",
    "svelte": "^5.56.4"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "pino": {
      "optional": true
    }
  }
}
