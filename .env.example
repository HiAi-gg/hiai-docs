# ============================================
# hiai-docs Environment Configuration
# Copy to .env and fill in your values
# ============================================
#
# Wave 0 (W0.1) — Generate new random secrets before deployment.
# Use: openssl rand -hex 32
# IMPORTANT: Each domain MUST use its own secret. Do NOT reuse
# BETTER_AUTH_SECRET for CSRF or MINIO_SECRET_KEY for webhooks.
# ============================================

# Note: DATABASE_URL is constructed from DB_* vars above by docker-compose.
# For local dev without Docker, set DATABASE_URL directly in .env.

# --- Database (shared ai-core infra) ---
DB_USER=aiuser
DB_PASSWORD=changeme
DB_NAME=hiai_docs
DB_HOST=localhost
DB_PORT=5433

# --- Auth ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-to-random-32-chars
BETTER_AUTH_URL=http://localhost:50700

# --- CSRF ---
# Dedicated signing key for CSRF tokens. Must differ from BETTER_AUTH_SECRET.
# Generate with: openssl rand -hex 32
CSRF_SECRET=change-me-to-random-32-chars

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests.
# Required for local development (frontend on port 50701, backend on 50700).
# In production, set to your frontend URL(s).
CORS_ORIGINS=http://localhost:50701,http://127.0.0.1:50701

# --- MinIO (shared ai-core infra) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9020
MINIO_ACCESS_KEY=minioadmin
# Generate with: openssl rand -hex 32
MINIO_SECRET_KEY=change-me-to-random-32-chars
MINIO_BUCKET=hiai-docs
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9020

# --- Webhooks ---
# Dedicated HMAC key for inbound webhooks. Must differ from MINIO_SECRET_KEY.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-random-32-chars

# --- Redis (shared ai-core infra) ---
REDIS_URL=redis://localhost:6384

# --- Embeddings ---
# Primary provider: any OpenAI-compatible embeddings API.
# Leave empty to disable embeddings (semantic search degrades to text-only).
#
# Examples:
#   OpenRouter:  EMBEDDING_BASE_URL=https://openrouter.ai/api/v1  EMBEDDING_MODEL=openai/text-embedding-3-small
#   Ollama:      EMBEDDING_BASE_URL=http://localhost:11434        EMBEDDING_MODEL=nomic-embed-text
#   Voyage AI:   EMBEDDING_BASE_URL=https://api.voyageai.com/v1   EMBEDDING_MODEL=voyage-3-lite
#   OpenAI:      EMBEDDING_BASE_URL=https://api.openai.com/v1     EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Optional fallback provider (tried if primary fails). Same format as above.
# EMBEDDING_FALLBACK_BASE_URL=
# EMBEDDING_FALLBACK_API_KEY=
# EMBEDDING_FALLBACK_MODEL=

# --- API Key Auth (for bots / programmatic access) ---
# If set, requests with `Authorization: Bearer <key>` bypass Better Auth sessions.
# Must be a unique random value (do NOT reuse BETTER_AUTH_SECRET).
HIAI_DOCS_API_KEY=
# The user ID assigned to API key-authenticated requests. Defaults to "api-key-user".
OWNER_ID=api-key-user

# --- App ---
API_PORT=50700
WEB_PORT=50701
NODE_ENV=development
LOG_LEVEL=info
