# hiai-docs unified environment
# `bash scripts/quickstart.sh` copies this file to .env, generates the local
# infrastructure secrets, and leaves only the provider choice for the user.
# Manual users may still copy this file and edit the values marked with CHANGE.
# Every variable here is consumed by `backend/src/lib/config.ts` (Zod
# schema). If a variable is missing the config layer uses the in-code
# default; do NOT rely on the docker-compose.yml defaults for prod.

# === DATABASE ==================================================================
# One PostgreSQL 18 image with pgvector + pgvectorscale + Apache AGE.
# `DB_PORT` is the HOST port; inside the container the listener is on 5432.
DB_USER=aiuser
DB_PASSWORD=change-me-generate-a-unique-owner-password
# Generate with: openssl rand -hex 32 (hex avoids URL escaping issues)
HIAI_APP_PASSWORD=change-me-generate-a-unique-runtime-password
DB_NAME=hiai_docs
DB_PORT=5437
# Runtime API connection (must use the non-superuser role).
DATABASE_URL=postgresql://hiai_app:change-me-generate-a-unique-runtime-password@localhost:5437/hiai_docs
# Migration-owner connection (used only by `hiai-docs migrate`).
MIGRATION_DATABASE_URL=postgresql://aiuser:change-me-generate-a-unique-owner-password@localhost:5437/hiai_docs

# === AUTH ======================================================================
# Generate with: openssl rand -hex 32
# CHANGE-ME: Generate with `openssl rand -hex 32` and keep secure
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:50700
# CHANGE-ME: Generate with `openssl rand -hex 32` and keep secure
CSRF_SECRET=change-me-generate-with-openssl-rand-hex-32
WEBHOOK_SECRET=change-me-generate-new-key-for-webhooks
CORS_ORIGINS=http://localhost:50701,http://127.0.0.1:50701

# === OBJECT STORAGE (SeaweedFS, S3-compatible) ===========================
STORAGE_PORT=50702
# SeaweedFS filer web UI host port (the S3 gateway remains STORAGE_PORT).
STORAGE_UI_PORT=50703
STORAGE_ACCESS_KEY=hiai-docs
STORAGE_SECRET_KEY=change-me-to-random-32-chars
STORAGE_BUCKET=hiai-docs
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# === EMBEDDINGS (dense vector model) ========================================
# One-line provider choice for quickstart. Keep `openrouter` and paste only
# OPENROUTER_API_KEY, or set `ollama` and adjust OLLAMA_PORT if needed.
AI_PROVIDER=openrouter
OLLAMA_PORT=11434
# Public default: OpenRouter with one primary model and one same-dimension
# fallback. Paste your key once into OPENROUTER_API_KEY below. The runtime
# passes it to both providers unless an explicit EMBEDDING_*_API_KEY is set.
# Every provider request is required to return the fixed 1024-dimensional
# vector used by the PostgreSQL schema.
#
# OpenRouter setup (recommended for users who do not want to run Ollama):
#   OPENROUTER_API_KEY=change-me-paste-your-openrouter-key-here
#   EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
#   EMBEDDING_MODEL=openai/text-embedding-3-small
#   EMBEDDING_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
#   EMBEDDING_FALLBACK_MODEL=baai/bge-m3
#
# Local Ollama example (no API key, model is the chat / embedding tag):
#   EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
#   EMBEDDING_API_KEY=
#   EMBEDDING_MODEL=bge-m3            # 1024-dim
# To switch fully to Ollama, replace the OpenRouter values with the local
# values above and remove OPENROUTER_API_KEY from your .env.
OPENROUTER_API_KEY=change-me-paste-your-openrouter-key-here
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_TIMEOUT_MS=20000
EMBEDDING_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_FALLBACK_API_KEY=
EMBEDDING_FALLBACK_MODEL=baai/bge-m3

# === GRAPHRAG (Apache AGE, lives in the same PostgreSQL) ==================
# The LLM used for entity extraction. Output MUST be JSON with shape
# `{"entities": [...]}`. Use an instruct / chat model, NOT the
# embedding model.
#
# Local Ollama example (8B+ chat model with JSON mode):
#   GRAPH_EXTRACT_BASE_URL=http://host.docker.internal:11434/v1
#   GRAPH_EXTRACT_MODEL=llama3.1
# For reasoning models such as Qwen3 on Ollama, also set:
#   GRAPH_EXTRACT_REASONING_EFFORT=none
# OpenRouter public profile. GraphRAG extraction and automatic graph expansion
# are enabled in this reference profile after the key is supplied:
#   GRAPH_EXTRACT_BASE_URL=https://openrouter.ai/api/v1
#   GRAPH_EXTRACT_MODEL=mistralai/ministral-14b-2512
#   GRAPH_EXTRACT_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
#   GRAPH_EXTRACT_FALLBACK_MODEL=google/gemma-4-31b-it
# Exact OpenRouter hosts may reuse OPENROUTER_API_KEY when a provider-specific
# key is blank. Local no-auth hosts may leave GRAPH_EXTRACT_*_API_KEY blank;
# custom providers may set a dedicated key. The shared key is never inherited
# by non-OpenRouter endpoints, and embedding credentials are never reused.
#
# IMPORTANT: GRAPH_EXTRACT_BASE_URL MUST be set explicitly in production.
# The code falls back to EMBEDDING_BASE_URL if GRAPH_EXTRACT_BASE_URL is
# empty, but embedding endpoints (e.g. Ollama /api/embeddings) are NOT
# compatible with chat-completion requests. Always set a dedicated
# extraction LLM URL that supports POST /chat/completions.
GRAPH_EXTRACT_ENABLED=true
GRAPH_SEARCH_ENABLED=true
GRAPH_EXTRACT_BASE_URL=https://openrouter.ai/api/v1
GRAPH_EXTRACT_API_KEY=
GRAPH_EXTRACT_MODEL=mistralai/ministral-14b-2512
GRAPH_EXTRACT_REASONING_EFFORT=none
GRAPH_EXTRACT_TIMEOUT_MS=30000
GRAPH_EXTRACT_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
GRAPH_EXTRACT_FALLBACK_API_KEY=
GRAPH_EXTRACT_FALLBACK_MODEL=google/gemma-4-31b-it
GRAPH_EXTRACT_MIN_CONFIDENCE=0.5

# === SEARCH EXPANSION AND RANKING ============================================
# A single structured expansion pass runs only when the fast retrieval pass is
# uncertain. OpenRouter URLs reuse OPENROUTER_API_KEY; local/custom URLs must
# set SEARCH_EXPANSION_API_KEY explicitly (the shared key is never forwarded).
SEARCH_EXPANSION_ENABLED=true
SEARCH_EXPANSION_BASE_URL=https://openrouter.ai/api/v1
SEARCH_EXPANSION_API_KEY=
SEARCH_EXPANSION_MODEL=mistralai/ministral-14b-2512
SEARCH_EXPANSION_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
SEARCH_EXPANSION_FALLBACK_API_KEY=
SEARCH_EXPANSION_FALLBACK_MODEL=google/gemma-4-31b-it
SEARCH_EXPANSION_TIMEOUT_MS=6000
SEARCH_VECTOR_PROVIDER_TIMEOUT_MS=2500
SEARCH_EXPANSION_CACHE_TTL_SECONDS=86400
SEARCH_EXPANSION_MAX_VARIANTS=12
SEARCH_EXPANSION_ESTIMATED_COST_MICROUNITS=0
SEARCH_RRF_K=60
SEARCH_EXACT_BOOST=0.02
SEARCH_CHANNEL_AGREEMENT_BOOST=0.01
SEARCH_GRAPH_MAX_CONTRIBUTION=0.03
SEARCH_VECTOR_MIN_SIMILARITY=0.35
SEARCH_FUZZY_MIN_SIMILARITY=0.25
SEARCH_MIN_CHANNEL_AGREEMENT=2
SEARCH_GRAPH_SEED_LIMIT=10
SEARCH_GRAPH_MAX_HOPS=2
SEARCH_GRAPH_RESULT_LIMIT=20

# Legacy hybrid weights remain accepted for compatibility with older clients;
# the current search path uses channel retrieval plus reciprocal rank fusion
# (RRF), not these weighted-score values.
HYBRID_TEXT_WEIGHT=0.4
HYBRID_SEMANTIC_WEIGHT=0.6
# Legacy graph multiplier retained for older integrations. Automatic GraphRAG
# applies a bounded graph contribution through SEARCH_GRAPH_MAX_CONTRIBUTION.
GRAPH_EXPANSION_BOOST=0.3

# === CHUNKING ==================================================================
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# === DURABLE BULLMQ PIPELINE ===================================================
QUEUE_PREPARE_CONCURRENCY=2
QUEUE_EMBED_CONCURRENCY=3
QUEUE_GRAPH_CONCURRENCY=2
QUEUE_SUMMARY_CONCURRENCY=1
QUEUE_FINALIZE_CONCURRENCY=2
QUEUE_EMBED_BATCH_SIZE=5
QUEUE_MAX_ACTIVE_BATCHES_PER_DOCUMENT=2
QUEUE_MAX_ACTIVE_PREPARE_PER_OWNER=2
QUEUE_MAX_ACTIVE_EMBED_PER_OWNER=4
QUEUE_MAX_ACTIVE_GRAPH_PER_OWNER=1
QUEUE_JOB_ATTEMPTS=5
QUEUE_RETRY_BASE_DELAY_MS=1000
QUEUE_RECOVERY_STALE_AFTER_MS=120000
QUEUE_COMPLETED_RETENTION_COUNT=1000
QUEUE_FAILED_RETENTION_COUNT=5000
QUEUE_SHUTDOWN_GRACE_MS=30000

# Local providers use concurrency only; remote providers also use RPM/retries.
PROVIDER_LIMITER_MODE=remote
PROVIDER_MAX_CONCURRENCY=4
PROVIDER_REQUESTS_PER_MINUTE=0
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BASE_DELAY_MS=250
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=5
PROVIDER_CIRCUIT_COOLDOWN_MS=30000

# === RE-EMBED BATCH CAPS =====================================================
# Cap on documents re-embedded per tag/folder/category mutation. 0 = no cap.
FOLDER_REEMBED_BATCH_SIZE=100
CATEGORY_REEMBED_BATCH_SIZE=100
TAG_REEMBED_BATCH_SIZE=500

# === ADMIN =====================================================================
# Generate with: openssl rand -hex 32
# CHANGE-ME: Generate with `openssl rand -hex 32` and keep secure
HIAI_DOCS_API_KEY=change-me-generate-new-key
# Owner (admin) user UUID. Set to the id of the first user you
# register, or leave as-is for the seed admin created by `bun run db:push`.
# CHANGE-ME: Replace with the actual user UUID from auth after first registration
OWNER_ID=00000000-0000-4000-8000-000000000001

# === API KEYS =================================================================
# Optional salt for API key hashing. If unset, raw SHA-256 is used.
API_KEY_HASH_SECRET=change-me-to-random-32-chars
# AES-GCM key used only for owner-recoverable category API keys.
API_KEY_ENCRYPTION_SECRET=change-me-to-random-32-chars-long
# Identity used to namespace public PWA caches. Override the deployment value
# for every independently deployed instance.
PUBLIC_APP_ID=docsmint
PUBLIC_DEPLOYMENT_ID=local
