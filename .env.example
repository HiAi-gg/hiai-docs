# hiai-docs unified environment
# Copy this file to .env and edit the values marked with CHANGE.
# Every variable here is consumed by `backend/src/lib/config.ts` (Zod
# schema). If a variable is missing the config layer uses the in-code
# default; do NOT rely on the docker-compose.yml defaults for prod.

# === DATABASE ==================================================================
# One PostgreSQL 18 image with pgvector + pgvectorscale + Apache AGE.
# `DB_PORT` is the HOST port; inside the container the listener is on 5432.
DB_USER=aiuser
DB_PASSWORD=aipassword
DB_NAME=hiai_docs
DB_PORT=5437
DATABASE_URL=postgresql://aiuser:aipassword@localhost:5437/hiai_docs

# === AUTH ======================================================================
# Generate with: openssl rand -hex 32
# CHANGE-ME: Generate with `openssl rand -hex 32` and keep secure
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:50700
# CHANGE-ME: Generate with `openssl rand -hex 32` and keep secure
CSRF_SECRET=change-me-generate-with-openssl-rand-hex-32
WEBHOOK_SECRET=change-me-generate-new-key-for-webhooks
CORS_ORIGINS=http://localhost:50701,http://127.0.0.1:50701

# === OBJECT STORAGE (SeaweedFS, S3-compatible) ===========================
STORAGE_PORT=9020
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme
STORAGE_BUCKET=hiai-docs
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# === EMBEDDINGS (dense vector model) ========================================
# Used to embed every chunk on save. Output MUST be a flat float vector;
# dimensionality is read from the first response.
#
# Local Ollama example (no API key, model is the chat / embedding tag):
#   EMBEDDING_BASE_URL=http://localhost:11434/api
#   EMBEDDING_API_KEY=
#   EMBEDDING_MODEL=bge-m3            # 1024-dim
# OpenAI example:
#   EMBEDDING_BASE_URL=https://api.openai.com/v1
#   EMBEDDING_API_KEY=sk-...
#   EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=http://localhost:11434/api
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3

# === GRAPHRAG (Apache AGE, lives in the same PostgreSQL) ==================
# The LLM used for entity extraction. Output MUST be JSON with shape
# `{"entities": [...]}`. Use an instruct / chat model, NOT the
# embedding model.
#
# Local Ollama example (8B+ chat model with JSON mode):
#   GRAPH_EXTRACT_BASE_URL=http://localhost:11434/api
#   GRAPH_EXTRACT_MODEL=llama3.1
GRAPH_EXTRACT_ENABLED=false
GRAPH_SEARCH_ENABLED=false
GRAPH_EXTRACT_BASE_URL=http://localhost:11434/v1
GRAPH_EXTRACT_MODEL=llama3.1
GRAPH_EXTRACT_MIN_CONFIDENCE=0.5

# === SEARCH RANKING ==========================================================
# score = HYBRID_TEXT_WEIGHT * full_text + HYBRID_SEMANTIC_WEIGHT * cosine
HYBRID_TEXT_WEIGHT=0.4
HYBRID_SEMANTIC_WEIGHT=0.6
# Multiplier on graph-neighbor scores when GRAPH_SEARCH_ENABLED=true
GRAPH_EXPANSION_BOOST=0.3

# === CHUNKING ==================================================================
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# === RE-EMBED BATCH CAPS =====================================================
# Cap on documents re-embedded per tag/folder/category mutation. 0 = no cap.
FOLDER_REEMBED_BATCH_SIZE=100
CATEGORY_REEMBED_BATCH_SIZE=100
TAG_REEMBED_BATCH_SIZE=500

# === ADMIN =====================================================================
# Generate with: openssl rand -hex 32
# CHANGE-ME: Generate with `openssl rand -hex 32` and keep secure
HIAI_DOCS_API_KEY=change-me-generate-new-key
# Owner (admin) user UUID. Set to the id of the first user you
# register, or leave as-is for the seed admin created by `bun run db:push`.
# CHANGE-ME: Replace with the actual user UUID from auth after first registration
OWNER_ID=your-user-uuid-from-auth
