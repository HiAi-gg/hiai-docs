# ============================================
# hiai-docs Environment Configuration
# Copy to .env and fill in your values
# ============================================
#
# Wave 0 (W0.1) — Generate new random secrets before deployment.
# Use: openssl rand -hex 32
# IMPORTANT: Each domain MUST use its own secret. Do NOT reuse
# BETTER_AUTH_SECRET for CSRF or MINIO_SECRET_KEY for webhooks.
# ============================================

# Note: DATABASE_URL is constructed from DB_* vars above by docker-compose.
# For local dev without Docker, set DATABASE_URL directly in .env.

# --- Database (shared ai-core infra) ---
DB_USER=aiuser
DB_PASSWORD=changeme
DB_NAME=hiai_docs
DB_HOST=localhost
DB_PORT=5433

# --- Auth ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-to-random-32-chars
BETTER_AUTH_URL=http://localhost:50700

# --- CSRF ---
# Dedicated signing key for CSRF tokens. Must differ from BETTER_AUTH_SECRET.
# Generate with: openssl rand -hex 32
CSRF_SECRET=change-me-to-random-32-chars

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests.
# Required for local development (frontend on port 50701, backend on 50700).
# In production, set to your frontend URL(s).
CORS_ORIGINS=http://localhost:50701,http://127.0.0.1:50701

# --- MinIO (shared ai-core infra) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9020
MINIO_ACCESS_KEY=minioadmin
# Generate with: openssl rand -hex 32
MINIO_SECRET_KEY=change-me-to-random-32-chars
MINIO_BUCKET=hiai-docs
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9020

# --- Webhooks ---
# Dedicated HMAC key for inbound webhooks. Must differ from MINIO_SECRET_KEY.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-random-32-chars

# --- Redis (shared ai-core infra) ---
REDIS_URL=redis://localhost:6384

# --- Embeddings ---
# Primary provider: any OpenAI-compatible embeddings API.
# Leave empty to disable embeddings (semantic search degrades to text-only).
#
# Examples:
#   OpenRouter:  EMBEDDING_BASE_URL=https://openrouter.ai/api/v1  EMBEDDING_MODEL=openai/text-embedding-3-small
#   Ollama:      EMBEDDING_BASE_URL=http://localhost:11434        EMBEDDING_MODEL=nomic-embed-text
#   Voyage AI:   EMBEDDING_BASE_URL=https://api.voyageai.com/v1   EMBEDDING_MODEL=voyage-3-lite
#   OpenAI:      EMBEDDING_BASE_URL=https://api.openai.com/v1     EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Optional fallback provider (tried if primary fails). Same format as above.
# EMBEDDING_FALLBACK_BASE_URL=
# EMBEDDING_FALLBACK_API_KEY=
# EMBEDDING_FALLBACK_MODEL=

# --- API Key Auth (for bots / programmatic access) ---
# If set, requests with `Authorization: Bearer <key>` bypass Better Auth sessions.
# Must be a unique random value (do NOT reuse BETTER_AUTH_SECRET).
HIAI_DOCS_API_KEY=
# The user ID assigned to API key-authenticated requests. Defaults to "api-key-user".
OWNER_ID=api-key-user

# --- App ---
API_PORT=50700
WEB_PORT=50701
NODE_ENV=development
LOG_LEVEL=info

# Version retention (number of auto-saved versions to keep per document)
VERSION_RETENTION_COUNT=50

# --- Embedding pipeline tuning ---
# Chunking (defaults: 500 tokens, 50 overlap). Workers chunk documents
# before embedding; overlap tokens ensure semantic continuity across chunk
# boundaries. Reduce CHUNK_TARGET_TOKENS for shorter, denser chunks.
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Hybrid search weights (both must be in [0, 1]). Defaults preserve the
# historical 0.4 text / 0.6 semantic balance. Set them carefully so the
# two weights still describe the relative importance of each signal.
HYBRID_TEXT_WEIGHT=0.4
HYBRID_SEMANTIC_WEIGHT=0.6

# Metadata-triggered re-embed batch caps. When a folder / category / tag
# is renamed or deleted, every affected document needs a fresh embedding
# because the preamble includes those names. The cap bounds how many docs
# can be re-embedded in a single tick so a rename of a mega-folder does
# not spike embedding costs. Set to 0 to disable the cap (process
# everything in one go — not recommended for production with >10k docs
# per folder).
FOLDER_REEMBED_BATCH_SIZE=100
CATEGORY_REEMBED_BATCH_SIZE=100
TAG_REEMBED_BATCH_SIZE=500

# --- GraphRAG (Apache AGE) — OPTIONAL ---
# GraphRAG layers an entity-relation graph over the existing vector search.
# Both feature flags default to false; the graph code paths stay dormant
# until the operator explicitly enables them. AGE runs as a separate
# PostgreSQL 17 instance (see docker-compose.yml, port 5438).
GRAPH_EXTRACT_ENABLED=false
GRAPH_SEARCH_ENABLED=false

# Graph-neighbor score multiplier when merging into a result list. Range
# [0, 2]; default 0.3 keeps the ranking honest — a graph neighbor scores
# BELOW a single semantic match but ABOVE the noise floor. Tune up for
# graph-heavy corpora, down if graph results crowd out semantic hits.
GRAPH_EXPANSION_BOOST=0.3

# Connection string for the AGE Postgres instance. When absent, graph
# endpoints return { available: false, reason: "AGE_DATABASE_URL not set" }.
AGE_DATABASE_URL=

# Minimum confidence (0.0-1.0) for entities to be persisted. Entities
# extracted by the LLM with confidence strictly below this threshold are
# dropped during parsing — they still count as cache misses but never
# reach AGE. Default 0.5 keeps moderate-confidence extractions while
# discarding speculative ones.
GRAPH_EXTRACT_MIN_CONFIDENCE=0.5

# LLM used by entity extraction. Defaults to EMBEDDING_MODEL when unset.
GRAPH_EXTRACT_MODEL=

# Base URL for the LLM that performs entity extraction. This endpoint MUST
# accept OpenAI-compatible chat completion requests
# (POST {url}/chat/completions). When absent, falls back to EMBEDDING_BASE_URL
# — which is usually WRONG (embedding endpoint != chat endpoint). Set this
# explicitly for production.
GRAPH_EXTRACT_BASE_URL=

# API key for the entity extraction LLM. Defaults to EMBEDDING_API_KEY
# when absent.
GRAPH_EXTRACT_API_KEY=

# Optional fallback extraction LLM (same format as the primary).
# GRAPH_EXTRACT_FALLBACK_BASE_URL=
# GRAPH_EXTRACT_FALLBACK_API_KEY=
# GRAPH_EXTRACT_FALLBACK_MODEL=

# --- Admin endpoints — OPTIONAL ---
ADMIN_CROSS_TENANT=true