{
  "name": "@hiai-docs/workspace",
  "private": true,
  "type": "module",
  "browser": {
	"./packages/sdk/dist/lifecycle.js": false,
	"./packages/sdk/dist/workspace.js": false
  },
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "description": "The lightweight, AI-native self-hosted knowledge base \u2014 built-in RAG, hybrid semantic search, and a clean REST API for AI agents.",
  "repository": {
    "type": "git",
    "url": "https://github.com/HiAi-gg/docsmint"
  },
  "homepage": "https://github.com/hiai-gg/docsmint#readme",
  "bugs": {
    "url": "https://github.com/hiai-gg/docsmint/issues"
  },
  "keywords": [
    "knowledge-base",
    "ai-native",
    "wiki",
    "markdown",
    "ai-embeddings",
    "rag",
    "semantic-search",
    "self-hosted",
    "pgvector",
    "ollama",
    "local-llm",
    "pwa",
    "progressive-web-app",
    "offline-knowledge-base",
    "docsmint",
    "outline-alternative",
    "docmost-alternative"
  ],
  "main": "./packages/sdk/dist/index.js",
  "types": "./packages/sdk/dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./packages/sdk/dist/index.js",
      "types": "./packages/sdk/dist/index.d.ts"
    },
    "./sdk": {
      "import": "./packages/sdk/dist/index.js",
      "types": "./packages/sdk/dist/index.d.ts"
    },
    "./lifecycle": {
      "browser": "./packages/sdk/dist/server-only-browser-entry.js",
      "import": "./packages/sdk/dist/lifecycle.js",
      "types": "./packages/sdk/dist/lifecycle.d.ts"
    },
    "./workspace": {
      "browser": "./packages/sdk/dist/server-only-browser-entry.js",
      "import": "./packages/sdk/dist/workspace.js",
      "types": "./packages/sdk/dist/workspace.d.ts"
    },
    "./frontend/dashboard": { "import": "./packages/sdk/dist/frontend/dashboard.js", "types": "./packages/sdk/dist/frontend/dashboard.d.ts" },
    "./frontend/search": { "import": "./packages/sdk/dist/frontend/search.js", "types": "./packages/sdk/dist/frontend/search.d.ts" },
    "./frontend/shared-document": { "import": "./packages/sdk/dist/frontend/shared-document.js", "types": "./packages/sdk/dist/frontend/shared-document.d.ts" },
    "./frontend/extension": { "import": "./packages/sdk/dist/frontend/extension.js", "types": "./packages/sdk/dist/frontend/extension.d.ts" },
    "./frontend/api/categories": { "import": "./packages/sdk/dist/frontend/api/categories.js", "types": "./packages/sdk/dist/frontend/api/categories.d.ts" },
    "./frontend/api/documents": { "import": "./packages/sdk/dist/frontend/api/documents.js", "types": "./packages/sdk/dist/frontend/api/documents.d.ts" },
    "./frontend/api/folders": { "import": "./packages/sdk/dist/frontend/api/folders.js", "types": "./packages/sdk/dist/frontend/api/folders.d.ts" },
    "./frontend/api/tags": { "import": "./packages/sdk/dist/frontend/api/tags.js", "types": "./packages/sdk/dist/frontend/api/tags.d.ts" },
    "./frontend/api/settings": { "import": "./packages/sdk/dist/frontend/api/settings.js", "types": "./packages/sdk/dist/frontend/api/settings.d.ts" },
    "./frontend/components/sidebar": { "import": "./packages/sdk/dist/frontend/components/sidebar.js", "types": "./packages/sdk/dist/frontend/components/sidebar.d.ts" },
    "./frontend/components/settings": { "import": "./packages/sdk/dist/frontend/components/settings.js", "types": "./packages/sdk/dist/frontend/components/settings.d.ts" },
    "./frontend/theme": { "import": "./packages/sdk/dist/frontend/theme.js", "types": "./packages/sdk/dist/frontend/theme.d.ts" },
    "./frontend/i18n": { "import": "./packages/sdk/dist/frontend/i18n.js", "types": "./packages/sdk/dist/frontend/i18n.d.ts" },
    "./schema": {
      "import": "./packages/db/src/schema.ts",
      "types": "./packages/db/src/schema.ts"
    },
    "./db": {
      "import": "./packages/db/src/index.ts",
      "types": "./packages/db/src/index.ts"
    },
    "./db/client": {
      "import": "./packages/db/src/client.ts",
      "types": "./packages/db/src/client.ts"
    },
    "./db/with-tenant": {
      "import": "./packages/db/src/with-tenant.ts",
      "types": "./packages/db/src/with-tenant.ts"
    },
    "./backend/lib/redis": {
      "import": "./backend/src/lib/redis-factory.ts",
      "types": "./backend/src/lib/redis-factory.ts"
    },
    "./backend/lib/storage": {
      "import": "./backend/src/lib/storage-factory.ts",
      "types": "./backend/src/lib/storage-factory.ts"
    },
    "./backend/lib/logger": {
      "import": "./backend/src/lib/logger.ts",
      "types": "./backend/src/lib/logger.ts"
    },
    "./backend/lib/rate-limit": {
      "import": "./backend/src/lib/rate-limit-factory.ts",
      "types": "./backend/src/lib/rate-limit-factory.ts"
    },
    "./backend/lib/api-keys": {
      "import": "./backend/src/lib/api-keys.ts",
      "types": "./backend/src/lib/api-keys.ts"
    },
    "./backend/lib/audit": {
      "import": "./backend/src/lib/audit.ts",
      "types": "./backend/src/lib/audit.ts"
    }
  },
  "bin": {
    "docsmint": "./packages/cli/src/index.ts",
    "docsmint-mcp": "./packages/mcp-server/src/index.ts",
    "hiai-docs": "./packages/cli/src/index.ts",
    "hiai-docs-mcp": "./packages/mcp-server/src/index.ts"
  },
  "files": [
    "packages/sdk/dist",
    "packages/db/src",
    "packages/cli/src",
    "packages/mcp-server/src",
    "backend/src",
    "frontend/src/lib/index.ts",
    "frontend/src/lib/extensions",
	"frontend/src/lib/hosts",
    "frontend/src/lib/stores/doc-tab-registry.svelte.ts",
    "frontend/src/lib/components/editor/shared-document.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">= 1.3.14"
  },
  "scripts": {
    "dev": "docker compose up -d",
    "build": "docker compose build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "build:sdk": "cd packages/sdk && bun run build",
	"test:package": "bun run build:sdk && bun run scripts/verify-packed-package.ts",
	"test:lifecycle:integration": "bun test packages/db/scripts/lifecycle-operations.integration.test.ts",
	"test:release": "bun run lint && bun run typecheck && bun run test && bun run test:package && git diff --check",
    "prepublishOnly": "cd packages/sdk && bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "ioredis": "^5.4.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "pino": "^10.0.0",
    "@sveltejs/kit": "^2.68.0",
    "svelte": "^5.56.4"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "pino": {
      "optional": true
    }
  }
}
