{
  "name": "hiai-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend",
    "packages/db"
  ],
  "engines": {
    "bun": ">= 1.3.14"
  },
  "scripts": {
    "dev": "bun run --parallel dev:api dev:web",
    "dev:api": "cd backend && bun run dev",
    "dev:web": "cd frontend && bun run dev",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "db:push": "cd packages/db && bun run db:push",
    "db:generate": "cd packages/db && bun run db:generate",
    "db:migrate": "cd packages/db && bun run db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "stop": "docker compose -f docker-compose.dev.yml down",
    "setup": "bun install && bun run docker:dev && bun run db:push",
    "export:openapi": "bun run scripts/export-openapi.ts"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "pino-pretty": "^13.1.3"
  }
}
