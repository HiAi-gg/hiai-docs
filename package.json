{
  "name": "hiai-docs",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend",
    "packages/db"
  ],
  "engines": {
    "bun": ">= 1.3.14"
  },
  "scripts": {
    "dev": "bun run --parallel dev:api dev:web",
    "dev:api": "bun --env-file=.env run --filter '@hiai-docs/backend' dev",
    "dev:web": "bun --env-file=.env run --filter '@hiai-docs/frontend' dev",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "db:push": "bun run --filter '@hiai-docs/db' db:push",
    "db:generate": "bun run --filter '@hiai-docs/db' db:generate",
    "db:migrate": "bun run --filter '@hiai-docs/db' db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "stop": "docker compose -f docker-compose.dev.yml down",
    "setup": "bun install && bun run docker:dev && bun run db:push",
    "export:openapi": "bun run scripts/export-openapi.ts",
    "mcp:dev": "bun run --filter '@hiai-docs/mcp-server' dev",
    "cli": "bun run --filter '@hiai-docs/cli' dev"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.49",
    "pino-pretty": "^13.1.3"
  },
  "dependencies": {
    "@hiai-gg/hiai-ui": "^0.0.8",
    "docx": "^9.7.1",
    "prosemirror-docx": "^0.6.1",
    "svelte-dnd-action": "^0.9.70"
  }
}