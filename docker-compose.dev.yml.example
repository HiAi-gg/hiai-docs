# hiai-docs Docker Compose (Development) — TEMPLATE
#
# Copy this file to docker-compose.dev.yml and fill in your local values:
#   cp docker-compose.dev.yml.example docker-compose.dev.yml
#
# The .example file is tracked in git; the actual docker-compose.dev.yml is
# gitignored. Adjust secrets, ports, and embedding provider settings for your
# machine, then `docker compose -f docker-compose.dev.yml up`.

services:
  # Custom PostgreSQL image with AGE, pgvector, and pgvectorscale.
  postgres:
    image: hiai-postgres:18-custom
    restart: unless-stopped
    ports:
      - "${DB_PORT:-5437}:5432"
    volumes:
      - pgdata:/var/lib/postgresql
    environment:
      POSTGRES_DB: ${DB_NAME:-hiai_docs}
      POSTGRES_USER: ${DB_USER:-aiuser}
      # Change this for any non-throwaway environment.
      POSTGRES_PASSWORD: ${DB_PASSWORD:-changeme}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-aiuser} -d ${DB_NAME:-hiai_docs}"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: "2"

  # Redis — used for caching, rate limiting, and job queues.
  redis:
    image: redis:8-alpine
    restart: unless-stopped
    ports:
      - "${REDIS_PORT:-6384}:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"

  # SeaweedFS — S3-compatible object storage for uploaded files (PDFs, etc.).
  # The fixed 9020/9021 host ports avoid clashing with other services.
  seaweedfs:
    image: chrislusf/seaweedfs:3.85
    restart: unless-stopped
    ports:
      - "9020:8333"   # S3 Gateway
      - "9021:8888"   # SeaweedFS Web UI (Filer)
    volumes:
      - seaweedfs_data:/data
    entrypoint: ["/bin/sh", "-ec"]
    command:
      - |
        printf '%s' "$$SEAWEEDFS_S3_CONFIG" > /data/s3.json
        exec /usr/bin/weed server -s3 -s3.port=8333 -s3.config=/data/s3.json -filer -filer.port=8888 -master.port=9333 -volume.port=8080 -dir=/data -ip=seaweedfs
    environment:
      SEAWEEDFS_S3_CONFIG: >-
        {"identities":[{"name":"hiai-docs","credentials":[{"accessKey":"${STORAGE_ACCESS_KEY:-minioadmin}","secretKey":"${STORAGE_SECRET_KEY:-minioadmin}"}],"actions":["Admin","Read","List","Tagging","Write"]}]}
      SEAWEEDFS_S3_CORS_ALLOW_ORIGIN: ${STORAGE_CORS_ALLOW_ORIGIN:-http://localhost:50701,http://127.0.0.1:50701}
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:8888/"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: "1"

  # Backend API (Bun + Elysia). Runs migrations, then watches src/.
  api:
    image: oven/bun:1.3.14-alpine
    working_dir: /mnt/ai_data/projects/hiai-docs
    restart: unless-stopped
    ports:
      - "${API_PORT:-50700}:50700"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      # Bind-mount source for live reload.
      # Host's node_modules (with workspace symlinks) are used directly.
      - ./:/mnt/ai_data/projects/hiai-docs
      - ../../packages/hiai-ui:/mnt/ai_data/packages/hiai-ui
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      seaweedfs:
        condition: service_healthy
    command:
      - sh
      - -c
      - "cd /mnt/ai_data/projects/hiai-docs/packages/db && DATABASE_URL=postgresql://${DB_USER:-aiuser}:${DB_PASSWORD:-changeme}@postgres:5432/${DB_NAME:-hiai_docs} bun run db:migrate && cd /mnt/ai_data/projects/hiai-docs/backend && bun run --watch src/index.ts"
    env_file: .env
    environment:
      DATABASE_URL: postgresql://hiai_app:${HIAI_APP_PASSWORD:-hiai_app_password}@postgres:5432/${DB_NAME:-hiai_docs}
      HIAI_APP_PASSWORD: ${HIAI_APP_PASSWORD:-hiai_app_password}
      REDIS_URL: redis://redis:6379
      STORAGE_ENDPOINT: seaweedfs
      STORAGE_PORT: 8333
      STORAGE_ACCESS_KEY: ${STORAGE_ACCESS_KEY:-minioadmin}
      STORAGE_SECRET_KEY: ${STORAGE_SECRET_KEY:-minioadmin}
      STORAGE_BUCKET: ${STORAGE_BUCKET:-hiai-docs}
      STORAGE_PUBLIC_ENDPOINT: localhost
      STORAGE_PUBLIC_PORT: 9020
      STORAGE_REGION: us-east-1
      STORAGE_FORCE_PATH_STYLE: true
      BETTER_AUTH_SECRET: ${BETTER_AUTH_SECRET:-dev-only-secret-replace-me}
      BETTER_AUTH_URL: ${BETTER_AUTH_URL:-http://localhost:50700}
      CORS_ORIGINS: ${CORS_ORIGINS:-http://localhost:50701,http://127.0.0.1:50701}
      # Embedding provider (OpenAI-compatible). Leave the *_FALLBACK_* values
      # empty to disable the secondary provider. Required for ingestion.
      EMBEDDING_BASE_URL: ${EMBEDDING_BASE_URL:-}
      EMBEDDING_API_KEY: ${EMBEDDING_API_KEY:-}
      EMBEDDING_MODEL: ${EMBEDDING_MODEL:-}
      EMBEDDING_FALLBACK_BASE_URL: ${EMBEDDING_FALLBACK_BASE_URL:-}
      EMBEDDING_FALLBACK_API_KEY: ${EMBEDDING_FALLBACK_API_KEY:-}
      EMBEDDING_FALLBACK_MODEL: ${EMBEDDING_FALLBACK_MODEL:-}
      API_PORT: ${API_PORT:-50700}
      NODE_ENV: development
      BODY_SIZE_LIMIT: "10485760"
      LOG_LEVEL: ${LOG_LEVEL:-debug}
      # Loaded from .env; explicit here for Docker (Bun's auto-load only
      # checks the cwd, which after `cd /app/backend` is backend/).
      HIAI_DOCS_API_KEY: ${HIAI_DOCS_API_KEY:-}
      OWNER_ID: ${OWNER_ID:-api-key-user}
      CSRF_SECRET: ${CSRF_SECRET:-dev-csrf-change-in-production}
      WEBHOOK_SECRET: ${WEBHOOK_SECRET:-dev-webhook-change-in-production}
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"

  # SvelteKit frontend (Vite dev server).
  web:
    image: oven/bun:1.3.14-alpine
    working_dir: /mnt/ai_data/projects/hiai-docs
    restart: unless-stopped
    ports:
      - "${WEB_PORT:-50701}:50701"
    volumes:
      - ./:/mnt/ai_data/projects/hiai-docs
      - ../../packages/hiai-ui:/mnt/ai_data/packages/hiai-ui
    depends_on:
      - api
    command:
      - sh
      - -c
      - "cd /mnt/ai_data/projects/hiai-docs/frontend && bun run dev"
    environment:
      API_URL: http://api:${API_PORT:-50700}
      PORT: ${WEB_PORT:-50701}
      WEB_PORT: ${WEB_PORT:-50701}
      NODE_ENV: development

volumes:
  pgdata:
  redis_data:
  seaweedfs_data:
